{
  "name": "ppt-to-video-voiceover",
  "version": "1.0.0",
  "description": "将 PowerPoint 演示文稿转换为带 AI 配音的 MP4 视频",
  "author": "MiniMax Agent",
  "homepage": "https://github.com/minimax-agent/ppt-to-video-skill",
  "repository": "https://github.com/minimax-agent/ppt-to-video-skill",
  "license": "MIT",
  "tags": [
    "ppt",
    "video",
    "voiceover",
    "tts",
    "presentation",
    "media",
    "converter"
  ],
  "categories": [
    "productivity",
    "media",
    "automation"
  ],
  "runtime": "python",
  "minOpenClawVersion": "2024.0.0",
  "env": {},
  "dependencies": {
    "python": [
      "python-pptx>=0.6.23",
      "moviepy>=1.0.3",
      "edge-tts>=6.1.12",
      "Pillow>=10.0.0"
    ],
    "system": [
      "ffmpeg",
      "libreoffice",
      "poppler-utils"
    ]
  },
  "commands": {
    "execute": "python ai_skill.py"
  },
  "permissions": {
    "file_read": true,
    "file_write": true,
    "network": true
  },
  "examples": [
    {
      "description": "基本转换",
      "input": "把这个 PPT 转为视频：/path/to/file.pptx"
    },
    {
      "description": "使用男声",
      "input": "用男声把 presentation.pptx 转为视频"
    },
    {
      "description": "自定义设置",
      "input": "把 test.pptx 转为视频，晓晓的声音，每页 20-30 秒"
    }
  ],
  "keywords": [
    "ppt",
    "powerpoint",
    "video",
    "voiceover",
    "tts",
    "audio",
    "converter"
  ]
}
